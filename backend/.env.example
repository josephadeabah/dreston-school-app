# --- Supabase ---------------------------------------------------------------
# Project Settings > API in your Supabase dashboard
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
SUPABASE_JWT_SECRET=YOUR-JWT-SECRET
# Project Settings > API > JWT Settings > JWT Secret

# --- SMS — Arkesel (Ghana-based, direct MTN/Telecel/AirtelTigo connections) --
# Sign up free at https://arkesel.com — no card required.
# 1. Create an account and generate an API key from your dashboard.
# 2. Keep ARKESEL_SANDBOX=true while testing: messages are validated but not
#    actually delivered, so you don't spend credit or need a live number.
# 3. When ready to send real texts: register a sender ID (Dreston Elite school
#    name), buy credit (pay-as-you-go, from about GHS 0.02/SMS), then set
#    ARKESEL_SANDBOX=false.
ARKESEL_API_KEY=YOUR-ARKESEL-API-KEY
ARKESEL_SENDER_ID=DrestonElit
ARKESEL_SANDBOX=true

# --- Email (Resend — generous free tier, no card required) -----------------
RESEND_API_KEY=YOUR-RESEND-API-KEY
RESEND_FROM_EMAIL=school@drestonelite.edu.gh

# --- App ---------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,https://your-frontend-domain.vercel.app
ENVIRONMENT=development
