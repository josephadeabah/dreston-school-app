# --- Supabase ---------------------------------------------------------------
# Project Settings > API in your Supabase dashboard
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
SUPABASE_JWT_SECRET=YOUR-JWT-SECRET
# Project Settings > API > JWT Settings > JWT Secret

# --- SMS (Africa's Talking — low cost, works well in Ghana/West Africa) -----
# Sign up free at https://africastalking.com (sandbox is free, live SMS ~ GHS 0.03-0.05/msg)
AT_USERNAME=sandbox
AT_API_KEY=YOUR-AFRICASTALKING-API-KEY
AT_SENDER_ID=DrestonElite

# --- Email (Resend — generous free tier, no card required) -----------------
RESEND_API_KEY=YOUR-RESEND-API-KEY
RESEND_FROM_EMAIL=school@drestonelite.edu.gh

# --- App ---------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,https://your-frontend-domain.vercel.app
ENVIRONMENT=development
